{
  "name": "mma-agent",
  "description": "Agent with all MMA MCP servers for database migration operations",
  "prompt": null,
  "mcpServers": {
    "postgres-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/workshop/MMA-Samples/postgres-client-mcp/target/postgresql-mcp-server-1.0.0.jar",
        "--spring.config.location=/workshop/MMA-Samples/postgres-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    },
    "sqlserver-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/workshop/MMA-Samples/sqlserver-client-mcp/target/sqlserver-mcp-server-1.0.0.jar",
        "--spring.config.location=/workshop/MMA-Samples/sqlserver-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    }
  },
  "tools": [
    "read",
